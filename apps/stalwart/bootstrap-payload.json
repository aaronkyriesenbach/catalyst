{
  "using": ["urn:ietf:params:jmap:core", "urn:stalwart:jmap"],
  "methodCalls": [
    [
      "x:Bootstrap/set",
      {
        "update": {
          "singleton": {
            "serverHostname": "stalwart.lab53.net",
            "defaultDomain": "lab53.net",
            "requestTlsCertificate": false,
            "generateDkimKeys": false,
            "dataStore": {
              "@type": "RocksDb",
              "path": "/opt/stalwart-mail"
            },
            "directory": {
              "@type": "Internal"
            },
            "tracer": {
              "@type": "Stdout",
              "level": "info"
            }
          }
        }
      },
      "bootstrap"
    ]
  ]
}
